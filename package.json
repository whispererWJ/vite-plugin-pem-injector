{
  "name": "@whisperer07/vite-plugin-pem-injector",
  "version": "1.1.1",
  "description": "Vite plugin to inject PEM files into environment variables",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite build --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build",
    "preversion": "npm run lint && npm run test",
    "postversion": "git push && git push --tags",
    "clean": "rm -rf dist node_modules package-lock.json",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "pem",
    "aes",
    "rsa",
    "encryption",
    "environment-variables",
    "crypto",
    "keys",
    "injector"
  ],
  "author": {
    "name": "whispererWJ",
    "email": "whisperer07@foxmail.com",
    "url": "https://github.com/whispererWJ"
  },
  "license": "MIT",
  "peerDependencies": {
    "vite": "^3.0.0 || ^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.3.2",
    "tslib": "^2.6.3",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whispererWJ/vite-plugin-pem-injector.git"
  },
  "bugs": {
    "url": "https://github.com/whispererWJ/vite-plugin-pem-injector/issues"
  },
  "homepage": "https://github.com/whispererWJ/vite-plugin-pem-injector#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
